// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Voor credentials provider
  image         String?
  role          String    @default("USER") // USER of ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  documents     Document[]
  lessonProgress UserLessonProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  filename    String
  filePath    String   // Locatie van het bestand op de server
  fileSize    Int      // In bytes
  mimeType    String
  content     String?  // Geëxtraheerde tekst uit PDF
  uploadedBy  String   // User ID
  uploadedAt  DateTime  @default(now())
  isActive    Boolean  @default(true) // Voor soft delete
  metadata    String?  // JSON metadata

  ambiguities   DocumentAmbiguity[]
  addenda       Addendum[]
  eLearningModules ELearningModule[]
  chunks        DocumentChunk[]

  user        User?    @relation(fields: [uploadedBy], references: [id])

  @@index([uploadedBy])
  @@index([isActive])
}

// Chunks met embeddings voor semantisch zoeken (OpenAI text-embedding-3-small)
model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int      // Volgorde van de chunk in het document
  content    String   // Tekst van deze chunk
  embedding  String   // JSON array van floats (1536 dims voor text-embedding-3-small)

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Addenda: aanvullende afspraken en besluiten bij een contract
model Addendum {
  id            String    @id @default(cuid())
  documentId    String    // Het contract waar dit addendum bij hoort
  title         String    // Korte omschrijving van het besluit/aanvulling
  description   String    // Toelichting / volledige tekst van de afspraak
  decisionDate  DateTime? // Datum van het besluit (optioneel)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  eLearningModules ELearningModule[]

  @@index([documentId])
  @@index([createdAt])
}

// Onduidelijkheden in contracten (voor de begrijker)
model DocumentAmbiguity {
  id          String   @id @default(cuid())
  documentId  String
  title       String   // Korte omschrijving van de onduidelijkheid
  description String   // Toelichting
  snippet     String?  // Relevante contractpassage
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Complexe onderwerpen (thema's die vaak terugkomen in vragen)
model ContractTopic {
  id             String   @id @default(cuid())
  name           String   // Naam van het onderwerp
  description    String?  // Korte toelichting
  complexity     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  questionCount  Int      @default(0) // Aantal gerelateerde vragen (kan later gevuld worden)
  createdAt      DateTime @default(now())

  @@index([complexity])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // "USER", "ASSISTANT", of "SYSTEM"
  content        String       // Bericht inhoud
  sources        String?      // JSON array van document IDs die gebruikt zijn
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
}

// E-learning modules: uit contracten, addenda of vaste modules (bijv. AVG)
model ELearningModule {
  id          String   @id @default(cuid())
  type        String   // "CONTRACT" | "ADDENDUM" | "AVG" (of andere vaste module)
  title       String
  description String
  paragraph   String?  // Korte categorie (bijv. "Contract", "Addendum", "AVG")
  duration    Int      @default(30) // geschatte minuten
  xpReward    Int      @default(100)
  sortOrder   Int      @default(0)
  contentJson String   // JSON: { sections: [...], quiz: [...] } (zelfde structuur als Lesson content)
  documentId  String?  // Bij type CONTRACT: welk document
  addendumId  String?  // Bij type ADDENDUM: welk addendum (of null bij "alle addenda"-module)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  addendum    Addendum? @relation(fields: [addendumId], references: [id], onDelete: SetNull)
  progress    UserLessonProgress[]

  @@index([type])
  @@index([documentId])
  @@index([addendumId])
}

// Voortgang gebruiker per e-learning module
model UserLessonProgress {
  id         String   @id @default(cuid())
  userId     String
  moduleId   String
  completed  Boolean  @default(false)
  completedAt DateTime?
  score      Int?     // Percentage quiz (0-100)
  xpEarned   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module ELearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}
