# Database (Neon PostgreSQL – voor zowel lokaal als productie)
# Maak een project op https://neon.tech en kopieer de connection string
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# OpenAI (voor AI-chat en embeddings)
OPENAI_API_KEY="your-openai-api-key"

# Bestandsopslag in productie (optioneel)
# Alleen nodig als je in productie geüploade PDF’s wilt bewaren.
# Zet BLOB_READ_WRITE_TOKEN in je Vercel-project (Storage → Blob store aanmaken).
# Lokaal: bestanden gaan naar de map uploads/
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
